Story</NuxtLink>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"hero-visual reveal-on-scroll delay-200\">\r\n          <div class=\"image-card glow-hover\">\r\n            <!-- Dynamic Placeholder -->\r\n            <div class=\"img-bg\"></div>\r\n          </div>\r\n          <!-- Floating Stats (Subtle) -->\r\n          <div class=\"floating-stat glass\">\r\n            <span class=\"stat-num\">10+</span>\r\n            <span class=\"stat-label\">Years Exp.</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- GravZero Ecosystem (Clean Cards) -->\r\n    <section class=\"section\">\r\n      <div class=\"container\">\r\n        <div class=\"section-head reveal-on-scroll\">\r\n          <h2>GravZero Ecosystem</h2>\r\n          <p>{{ t.gravzero.p1 }}</p>\r\n        </div>\r\n\r\n        <div class=\"ecosystem-grid\">\r\n          <!-- Team -->\r\n          <div class=\"eco-card glass reveal-on-scroll\">\r\n            <div class=\"card-icon\">🥋</div>\r\n            <h3>{{ t.gravzero.team.title }}</h3>\r\n            <p>{{ t.gravzero.team.desc }}</p>\r\n            <div class=\"card-arrow\">→</div>\r\n          </div>\r\n          \r\n          <!-- Studio -->\r\n          <div class=\"eco-card glass reveal-on-scroll delay-100\">\r\n            <div class=\"card-icon\">📸</div>\r\n            <h3>{{ t.gravzero.studio.title }}</h3>\r\n            <p>{{ t.gravzero.studio.desc }}</p>\r\n            <div class=\"card-arrow\">→</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- Philosophy (Minimal List) -->\r\n    <section class=\"section bg-soft\">\r\n      <div class=\"container\">\r\n        <h2 class=\"section-title reveal-on-scroll\">{{ t.philosophy.title }}</h2>\r\n        <div class=\"philosophy-list\">\r\n          <div \r\n            v-for=\"(item, i) in t.philosophy.items\" \r\n            :key=\"i\"\r\n            class=\"phi-item reveal-on-scroll\"\r\n            :class=\"`delay-${i*100}`\"\r\n          >\r\n            <span class=\"phi-num\">0{{ i + 1 }}</span>\r\n            <div class=\"phi-content\">\r\n              <h4>{{ item.title }}</h4>\r\n              <p>{{ item.desc }}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n    <!-- Services Banner -->\r\n    <section class=\"section\">\r\n      <div class=\"container\">\r\n        <div class=\"services-banner reveal-on-scroll\">\r\n          <span v-for=\"s in t.services.items\" :key=\"s\" class=\"service-pill\">{{ s }}</span>\r\n        </div>\r\n      </div>\r\n    </section>\r\n\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nconst { content } = useContent()\r\nconst t = computed(() => content.value)\r\n\r\nuseScrollReveal()\r\n</script>\r\n\r\n<style scoped>\r\n/* Layout Utils */\r\n.min-h-screen { min-height: 90vh; }\r\n.flex-center { display: flex; align-items: center; }\r\n.relative { position: relative; }\r\n.overflow-hidden { overflow: hidden; }\r\n\r\n/* Hero */\r\n.grid-split {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 4rem;\r\n  align-items: center;\r\n}\r\n\r\n.pill-label {\r\n  display: inline-block;\r\n  background: var(--bg-secondary);\r\n  color: var(--accent-blue);\r\n  padding: 0.5rem 1rem;\r\n  border-radius: 50px;\r\n  font-size: 0.9rem;\r\n  font-weight: 600;\r\n  margin-bottom: 1.5rem;\r\n}\r\n\r\n.hero-title {\r\n  font-size: 4.5rem;\r\n  font-weight: 800;\r\n  line-height: 1.1;\r\n  margin-bottom: 1.5rem;\r\n}\r\n\r\n.hero-desc {\r\n  font-size: 1.25rem;\r\n  color: var(--text-secondary);\r\n  margin-bottom: 2.5rem;\r\n  max-width: 500px;\r\n}\r\n\r\n.btn-group { display: flex; gap: 1rem; }\r\n\r\n.btn {\r\n  padding: 1rem 2rem;\r\n  border-radius: 12px;\r\n  font-weight: 600;\r\n  text-decoration: none;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.btn-primary {\r\n  background: var(--text-primary);\r\n  color: var(--bg-primary);\r\n}\r\n.btn-primary:hover {\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 10px 20px rgba(0,0,0,0.1);\r\n}\r\n\r\n.btn-outline {\r\n  border: 1px solid var(--border-color);\r\n  color: var(--text-primary);\r\n}\r\n.btn-outline:hover { background: var(--bg-secondary); }\r\n\r\n/* Visuals */\r\n.hero-visual { position: relative; }\r\n\r\n.image-card {\r\n  width: 100%;\r\n  aspect-ratio: 4/5;\r\n  border-radius: 24px;\r\n  overflow: hidden;\r\n  box-shadow: 0 20px 40px rgba(0,0,0,0.1);\r\n}\r\n.img-bg {\r\n  width: 100%;\r\n  height: 100%;\r\n  background-image: url('https://placehold.co/600x800/222/FFF?text=Keo+Moni');\r\n  background-size: cover;\r\n  background-position: center;\r\n  transition: transform 0.5s;\r\n}\r\n.image-card:hover .img-bg { transform: scale(1.05); }\r\n\r\n.floating-stat {\r\n  position: absolute;\r\n  bottom: 40px;\r\n  left: -40px;\r\n  padding: 1.5rem;\r\n  border-radius: 16px;\r\n  box-shadow: 0 10px 30px rgba(0,0,0,0.1);\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n.stat-num { font-size: 2rem; font-weight: 800; color: var(--accent-blue); line-height: 1; }\r\n.stat-label { font-size: 0.9rem; color: var(--text-secondary); }\r\n\r\n/* Glow */\r\n.glow-blob {\r\n  position: absolute;\r\n  top: -20%;\r\n  right: -10%;\r\n  width: 600px;\r\n  height: 600px;\r\n  background: var(--accent-blue);\r\n  opacity: 0.08;\r\n  filter: blur(100px);\r\n  z-index: -1;\r\n  border-radius: 50%;\r\n}\r\n\r\n/* GravZero */\r\n.section-head { text-align: center; margin-bottom: 4rem; }\r\n.section-head h2 { font-size: 3rem; margin-bottom: 1rem; }\r\n.section-head p { font-size: 1.2rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; }\r\n\r\n.ecosystem-grid {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 2rem;\r\n}\r\n\r\n.eco-card {\r\n  padding: 3rem;\r\n  border-radius: 24px;\r\n  border: 1px solid var(--border-color);\r\n  transition: all 0.3s;\r\n  cursor: pointer;\r\n  position: relative;\r\n}\r\n\r\n.eco-card:hover {\r\n  transform: translateY(-5px);\r\n  border-color: var(--accent-blue);\r\n  box-shadow: 0 10px 30px rgba(0,0,0,0.05);\r\n}\r\n\r\n.card-icon { font-size: 3rem; margin-bottom: 1.5rem; }\r\n.eco-card h3 { font-size: 2rem; margin-bottom: 1rem; }\r\n.card-arrow {\r\n  position: absolute;\r\n  bottom: 3rem;\r\n  right: 3rem;\r\n  font-size: 1.5rem;\r\n  opacity: 0;\r\n  transform: translateX(-10px);\r\n  transition: all 0.3s;\r\n}\r\n.eco-card:hover .card-arrow { opacity: 1; transform: translateX(0); }\r\n\r\n/* Philosophy List */\r\n.bg-soft { background: var(--bg-secondary); }\r\n\r\n.philosophy-list {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n  gap: 2rem;\r\n}\r\n\r\n.phi-item {\r\n  background: var(--bg-primary);\r\n  padding: 2rem;\r\n  border-radius: 16px;\r\n  /* box-shadow: 0 4px 10px rgba(0,0,0,0.03); */ /* Optional: cleaner without shadow */\r\n}\r\n\r\n.phi-num {\r\n  font-size: 1.5rem;\r\n  font-weight: 700;\r\n  color: var(--accent-blue);\r\n  opacity: 0.5;\r\n  margin-bottom: 1rem;\r\n  display: block;\r\n}\r\n.phi-content h4 { font-size: 1.5rem; margin-bottom: 0.5rem; }\r\n\r\n/* Services */\r\n.services-banner {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 1rem;\r\n  justify-content: center;\r\n}\r\n.service-pill {\r\n  padding: 0.75rem 1.5rem;\r\n  border: 1px solid var(--border-color);\r\n  border-radius: 50px;\r\n  font-size: 1rem;\r\n  color: var(--text-secondary);\r\n}\r\n\r\n/* Scroll Animation Classes (Matches useScrollReveal.ts) */\r\n.reveal-on-scroll { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }\r\n.reveal-on-scroll.in-view { opacity: 1; transform: translateY(0); }\r\n.delay-100 { transition-delay: 0.1s; }\r\n.delay-200 { transition-delay: 0.2s; }\r\n.delay-300 { transition-delay: 0.3s; }\r\n\r\n/* Responsive */\r\n@media (max-width: 900px) {\r\n  .grid-split { grid-template-columns: 1fr; gap: 3rem; }\r\n  .hero-content { order: 1; text-align: center; }\r\n  .hero-visual { order: 0; }\r\n  .btn-group { justify-content: center; }\r\n  .hero-title { font-size: 3rem; }\r\n  .floating-stat { display: none; }\r\n  .ecosystem-grid { grid-template-columns: 1fr; }\r\n}\r\n</style>\r\n"],"version":3}